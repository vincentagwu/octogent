{
  "name": "octogent",
  "private": true,
  "version": "0.0.0",
  "description": "Scratch monorepo for Octogent web-first product",
  "packageManager": "pnpm@10.4.1",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "start": "pnpm --filter @octogent/web dev",
    "dev": "pnpm --filter @octogent/web dev",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.13.10",
    "typescript": "^5.8.2",
    "vitest": "^3.0.7"
  }
}
